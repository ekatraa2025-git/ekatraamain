# Backend API URL - REQUIRED for cart, checkout, payment
# Production (Vercel):
EXPO_PUBLIC_API_URL=https://ekatraa-backend.vercel.app

# Local development (when backend runs with npm run dev):
# iOS/Web: EXPO_PUBLIC_API_URL=http://localhost:3000
# Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# Supabase (for auth, etc.)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
