# Backend API URL - REQUIRED for app API calls
# iOS/Web local: http://localhost:3000
# Android emulator local: http://10.0.2.2:3000
# Production: https://ekatraa-backend.vercel.app
# OpenRouter / AI image generation: the key lives only on the BACKEND for this URL (Vercel env or local .env.local), not in this file.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Feature flags
# Set to 1 to route ChatModal to Mastra planning endpoint
EXPO_PUBLIC_AI_PLANNING=1

# Optional app support number
EXPO_PUBLIC_EKATRAA_SUPPORT_PHONE=918422948781
